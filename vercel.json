      "maxDuration": 300,
      "includeFiles": "node_modules/@sparticuz/chromium/bin/**"
    },
    "api/trigger.js": {
      "maxDuration": 60,
      "includeFiles": "node_modules/@sparticuz/chromium/bin/**"
    },
    "api/data.js": { "maxDuration": 10 }
  }
}
